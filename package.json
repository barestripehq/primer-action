{
  "name": "primer-action",
  "version": "1.0.0",
  "description": "GitHub Action for primer vulnerability scanning",
  "main": "dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --format=cjs",
    "test": "vitest run",
    "package": "npm run build",
    "lint": "eslint src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barestripehq/primer-action.git"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/http-client": "^4.0.1",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
